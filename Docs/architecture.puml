@startuml ai-review-types
!theme plain

title Core — Type Relationships

interface "Rule" as IRule {
  + id: string
  + category: CheckCategory
  + severity: Severity
  + language: Language | "all"
  + check(content, path, lang): Finding[]
}

class "ReviewConfig" as Config {
  + anthropicApiKey?: string
  + model?: string
  + conventions?: string[]
  + ignorePatterns?: string[]
  + checks?: { ... }
  + languages?: Language[]
}

class "Finding" as Finding {
  + id: string
  + category: CheckCategory
  + severity: Severity
  + title: string
  + message: string
  + suggestion: string
  + file: string
  + line: number
  + column: number
  + endLine?: number
  + endColumn?: number
  + source: "static" | "ai"
  + ruleUrl?: string
}

class "FileReview" as FileReview {
  + file: string
  + language: Language
  + findings: Finding[]
  + cachedAt?: string
  + tokensUsed?: number
}

class "ReviewResult" as ReviewResult {
  + target: string
  + scannedAt: string
  + filesReviewed: number
  + totalFindings: number
  + byCategory: Record<CheckCategory, number>
  + bySeverity: Record<Severity, number>
  + files: FileReview[]
  + totalTokensUsed: number
  + estimatedCostUsd: number
}

class "ResultCache" as ResultCache {
  + constructor(cacheDir)
  + get(fileContent): Promise<FileReview | null>
  + set(fileContent, result): Promise<void>
  + clear(): Promise<void>
  + stats(): { entries, sizeKb }
}

class "loadConfig" as LoadConfig {
  + loadConfig(rootDir): Promise<ReviewConfig>
  + findConfigFile(startDir): Promise<string | null>
  + generateDefaultConfig(outputPath): Promise<void>
}

class "reviewFileWithAI" as AICaller {
  + reviewFileWithAI({file, lang, content, config, enabledChecks})
  : Promise<{ findings, tokensUsed }>
}

class "runReview" as RunReview {
  + runReview(rootDir, config, onProgress?): Promise<ReviewResult>
  + walkFiles(rootDir, config): Promise<FileEntry[]>
}

Finding --> FileReview : findings[]
FileReview --> ReviewResult : files[]
Config --> ReviewResult : passed to runReview

LoadConfig --> ReviewConfig : returns

IRule --> Finding : check() returns

RunReview --> ResultCache : uses
RunReview --> AICaller : uses (when AI enabled)
RunReview --> IRule : uses (deprecated, security, hallu)

@enduml
