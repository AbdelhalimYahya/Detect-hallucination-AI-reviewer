@startuml ai-review-architecture
!theme plain

' ======================================================================
' Title
' ======================================================================

title ai-review — Architecture Overview

' ======================================================================
' Component definitions
' ======================================================================

package "CLI (npx ai-review)" as CLI {
  [cli.ts] as CLIMain
  [Terminal Report] as TerminalReport
  [HTML Report] as HTMLReport
  [JSON Report] as JSONReport
}

package "@ai-review/core" as Core {
  [config.ts] as ConfigLoader
  [types.ts] as Types
  
  package "Scanner" as Scanner {
    [fileWalker.ts] as FileWalker
    [runReview.ts] as Orchestrator
  }
  
  package "Static Rules" as Rules {
    [deprecatedApis.ts] as DeprecatedRule
    [securityPatterns.ts] as SecurityRule
    [hallucinatedPackages.ts] as HalluCheck
  }
  
  package "AI" as AI {
    [batchCaller.ts] as BatchCaller
  }
  
  package "Cache" as Cache {
    [resultCache.ts] as ResultCache
  }
}

package "VS Code Extension" as VSCode {
  [extension.ts] as VSClient
  [server.ts] as LSP
}

package "Databases" as Databases {
  file "deprecated-node.json" as DBNode
  file "deprecated-react.json" as DBReact
  file "deprecated-python.json" as DBPython
}

package "External" as External {
  [npm Registry] as NPM
  [PyPI Registry] as PyPI
  [Anthropic API] as Anthropic
  [VS Code API] as VSCodeAPI
}

' ======================================================================
' Data flow
' ======================================================================

CLIMain --> ConfigLoader : loadConfig(targetDir)
CLIMain --> Orchestrator : runReview(targetDir, config)

Orchestrator --> FileWalker : walkFiles(rootDir, config)
FileWalker --> [Files on Disk] : read content

Orchestrator --> DeprecatedRule : check(content, path, lang)
Orchestrator --> SecurityRule : check(content, path, lang)
Orchestrator --> HalluCheck : check(content, path, lang)

DeprecatedRule --> DBNode : read (JS/TS files)
DeprecatedRule --> DBReact : read (JS/TS files)
DeprecatedRule --> DBPython : read (Python files)

HalluCheck --> NPM : HEAD {package-name}
HalluCheck --> PyPI : HEAD {package-name}

Orchestrator --> ResultCache : get(fileContent)
Orchestrator --> BatchCaller : reviewFileWithAI(file, lang, content, config)
BatchCaller --> Anthropic : messages.create()
BatchCaller --> ResultCache : set(fileContent, result)

Orchestrator --> [Per-file Findings]

CLIMain --> TerminalReport : printTerminalReport(result)
CLIMain --> HTMLReport : writeHtmlReport(result, path)
CLIMain --> JSONReport : fs.writeFile(jsonPath, JSON)

' ======================================================================
' VS Code flow
' ======================================================================

VSClient --> VSCodeAPI : activate()
VSClient --> LSP : start via LanguageClient
LSP --> ConfigLoader : loadConfig()
LSP --> DeprecatedRule : on open (fast)
LSP --> SecurityRule : on open (fast)
LSP --> HalluCheck : on save only
LSP --> ResultCache : on save (check cache)
LSP --> BatchCaller : on save (AI analysis)
LSP --> VSCodeAPI : sendDiagnostics()

' ======================================================================
' Relationships
' ======================================================================

CLI --> Core : depends on @ai-review/core
VSCode --> Core : depends on @ai-review/core
Core --> Types : implements
CLI --> Databases : copies at build time
VSCode --> Databases : copies at build time

' ======================================================================
' Notes
' ======================================================================

note right of Orchestrator
  For each file:
  1. Run all static rules in sequence
  2. Check content-hash cache for AI results
  3. Call AI only on cache miss
  4. Aggregate findings
end note

note right of ResultCache
  Key: SHA-256(file content)
  TTL: 30 days
  Location: ~/.ai-review/cache/
end note

note right of BatchCaller
  Always batches complexity +
  conventions into a single
  API call per file.
end note

' ======================================================================
' Legend
' ======================================================================

legend bottom
  |= Color |= Meaning |
  | Skinparam BackgroundColor | |
  | <#LIGHTBLUE>  | CLI layer |
  | <#LIGHTGREEN> | Core engine |
  | <#LIGHTCYAN>  | VS Code layer |
  | <#LIGHTYELLOW>| External dependencies |
  | Arrow direction | Data flow / dependency |
end legend

@enduml


' ======================================================================
' Second diagram: Review Pipeline Sequence
' ======================================================================

@startuml ai-review-pipeline
!theme plain

title ai-review — Review Pipeline Sequence

actor User as User
participant CLI as "CLI\n(commander)"
participant Orchestrator as "runReview()"
participant Walker as "fileWalker()"
participant Rules as "Static Rules\n(deprecatedApis,\nsecurityPatterns,\nhallucinatedPackages)"
participant Cache as "ResultCache\n(SHA-256)"
participant AI as "batchCaller\n(Anthropic)"
participant Report as "Reporters\n(Terminal, HTML, JSON)"

User -> CLI: ai-review scan ./src [--no-ai]
CLI -> Orchestrator: runReview(target, config)
Orchestrator -> Walker: walkFiles(rootDir, config)
Walker --> Orchestrator: FileEntry[]

loop for each file
  Orchestrator -> Rules: check(content, path, lang)
  Rules --> Orchestrator: Finding[] (static)
  
  alt API key available && AI checks enabled
    Orchestrator -> Cache: get(fileContent)
    alt Cache HIT
      Cache --> Orchestrator: FileReview (cached)
    else Cache MISS
      Orchestrator -> AI: reviewFileWithAI(...)
      AI --> Orchestrator: { findings, tokensUsed }
      Orchestrator -> Cache: set(fileContent, result)
    end
  else No API key or --no-ai
    Orchestrator -> Orchestrator: AI findings = []
  end
  
  Orchestrator -> Orchestrator: Merge static + AI findings
end

Orchestrator -> Orchestrator: computeSummary() → totals, cost

Orchestrator --> CLI: ReviewResult
CLI -> Report: print / write reports
CLI --> User: Terminal output + report files

@enduml


