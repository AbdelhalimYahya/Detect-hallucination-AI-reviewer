' ======================================================================
' Fourth diagram: LSP Server Architecture
' ======================================================================

@startuml ai-review-lsp
!theme plain

title VS Code / Cursor — LSP Architecture

actor Developer as Dev
participant "VS Code / Cursor" as Editor
participant "Extension Client\n(extension.ts)" as ExtClient
participant "LSP Server\n(server.ts)" as LSPServer
participant "@ai-review/core" as Core
collections "Diagnostics" as Diag

Dev -> Editor: Open or save .ts/.js/.py file
Editor -> ExtClient: activate() → start LanguageClient
ExtClient -> LSPServer: LSP Initialize
LSPServer --> ExtClient: capabilities

alt Document Opened
  Editor -> LSPServer: textDocument/didOpen
  LSPServer -> Core: runStaticAnalysis() → deprecatedApis + securityPatterns
  Core --> LSPServer: Diagnostic[]
  LSPServer -> ExtClient: textDocument/publishDiagnostics (static only)
  ExtClient -> Diag: Apply squiggles
else Document Saved
  Editor -> LSPServer: textDocument/didSave
  LSPServer -> Core: runStaticAnalysis() + runHallucinatedCheck()
  LSPServer -> Core: ResultCache.get() → check AI cache
  alt Cache HIT
    Core --> LSPServer: cached FileReview
  else Cache MISS
    LSPServer -> Core: reviewFileWithAI() → Anthropic API
    Core --> LSPServer: AI findings
    LSPServer -> Core: ResultCache.set()
  end
  LSPServer -> ExtClient: textDocument/publishDiagnostics (static + AI combined)
  ExtClient -> Diag: Update squiggles
else Manual Review Request
  Dev -> Editor: ai-review.reviewFile command
  Editor -> LSPServer: ai-review/reviewFile
  LSPServer -> Core: Full review (forced, no cache)
end

Dev -> Diag: Hover to see message + suggestion

@enduml


